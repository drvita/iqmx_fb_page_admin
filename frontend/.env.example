# IQISS Insight - Next.js Frontend Environment Configuration Template

# Facebook Application credentials (publicly accessible on the client side)
NEXT_PUBLIC_FB_APP_ID=your-facebook-app-id
NEXT_PUBLIC_FB_API_VERSION=v25.0

# API URL for Server Actions & Server Components (server-to-server calls)
API_URL=http://localhost:8000

# Session cookie expiration matching the backend JWT expiration (in days)
JWT_EXPIRE_DAYS=7
