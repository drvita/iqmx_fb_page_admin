# Monorepo Gitignore

# Entornos virtuales de Python (Backend)
.venv/
env/
venv/
ENV/

# Cache de Python y archivos compilados
**/__pycache__/
**/*.pyc
**/*.pyo
**/*.pyd
.pytest_cache/
.coverage
htmlcov/

# Next.js y Node (Frontend)
frontend/node_modules/
frontend/.next/
frontend/out/
frontend/build/

# Archivos de entorno y credenciales (Seguridad)
.env
.env.local
.env.*.local
api/.env
api/.env.local
frontend/.env
frontend/.env.local
frontend/.env.*.local

# Permitir explícitamente subir los archivos de ejemplo (.env.example)
!*.env.example
!**/.*.example
!**/.env.example

# Archivos de sistema y misc
.DS_Store
Thumbs.db
*.pem
*.key
*.crt
*.pfx

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
