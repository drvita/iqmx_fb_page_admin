# IQISS Insight - FastAPI API Environment Configuration Template

# Application Environment Mode (development / production)
APP_ENV=development

# JWT security settings
JWT_SECRET=replace-this-with-a-secure-random-secret-key-in-production
JWT_EXPIRE_DAYS=7

# Database Connection Settings
DB_USER=iqiss_user
DB_PASSWORD=iqiss_password
DB_HOST=localhost
DB_PORT=5432
DB_NAME=iqiss_insight

# Facebook Integration Credentials
FB_APP_ID=your-facebook-app-id
FB_APP_SECRET=your-facebook-app-secret
