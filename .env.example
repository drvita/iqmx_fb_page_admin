# IQISS Insight - Root Environment Configuration Template (Unified Database Setup)

# PostgreSQL Database Service Configuration
# Note: These values should match the DB settings configured in api/.env for the backend to connect.
POSTGRES_USER=iqiss_user
POSTGRES_PASSWORD=iqiss_password
POSTGRES_DB=iqiss_insight

# Ports mapping
DB_PORT=5432
DB_HOST=localhost

# General security configurations to align backend/frontend
JWT_SECRET=replace-this-with-a-secure-random-secret-key-in-production
JWT_EXPIRE_DAYS=7
