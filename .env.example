# =========================================================================
# IQISS Insight - Plantilla Unificada de Variables de Entorno (Root)
# Este archivo centraliza la configuración compartida para producción 
# (Coolify) y desarrollo local (Docker Compose).
# =========================================================================

# --- Configuración de Seguridad y Entorno ---
APP_ENV=production
JWT_SECRET=reemplazar_con_un_secreto_seguro_en_produccion
JWT_EXPIRE_DAYS=7

# --- Configuración de Base de Datos PostgreSQL ---
# En Coolify, reemplace con la dirección IP/Host, puerto y credenciales 
# proporcionados por la base de datos administrada del sistema.
# Para desarrollo local con docker-compose.local.yaml, use DB_HOST=postgres
DB_HOST=postgres
DB_PORT=5432
DB_USER=iqiss_user
DB_PASSWORD=iqiss_password
DB_NAME=iqiss_insight

# Variables de inicialización para la imagen de Postgres local (docker-compose.local.yaml)
POSTGRES_USER=iqiss_user
POSTGRES_PASSWORD=iqiss_password
POSTGRES_DB=iqiss_insight

# --- Configuración de API de Facebook (Meta Developer App) ---
FB_APP_ID=tu_fb_app_id
FB_APP_SECRET=tu_fb_app_secret

# --- Variables Públicas del Frontend (Next.js) ---
# NOTA: NEXT_PUBLIC_FB_APP_ID debe coincidir con FB_APP_ID
NEXT_PUBLIC_FB_APP_ID=tu_fb_app_id
NEXT_PUBLIC_FB_API_VERSION=v25.0

# URL pública o interna de resolución para consumir los endpoints del Backend
NEXT_PUBLIC_API_URL=http://localhost:8000
